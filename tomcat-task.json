{
  "family": "tomcat-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::748716953870:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "tomcat-container",
      "image": "748716953870.dkr.ecr.ap-south-1.amazonaws.com/tomcat:latest ",
      "essential": true,
      "cpu": 512,
      "memory": 1024,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ]
    }
  ]
}
